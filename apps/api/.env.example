DATABASE_URL="mysql://slist:slist@127.0.0.1:3306/slist"

# LLM: "openai" (default) or "ollama" (local, no API key)
LLM_PROVIDER="openai"
OPENAI_API_KEY="sk-..."
OPENAI_MODEL="gpt-4o-mini"

# When LLM_PROVIDER=ollama — start Ollama app or `ollama serve`, then: ollama pull llama3.2
# OLLAMA_HOST="http://127.0.0.1:11434"
# OLLAMA_MODEL="llama3.2"
PORT=4000
CORS_ORIGIN="http://localhost:3000"
JWT_SECRET="change-me-in-dev"
# Resolve tenant: slug from seed (default demo) or set explicit id
DEFAULT_COMPANY_SLUG="demo"
SEED_AUTH_EMAIL="admin@slist.dev"
SEED_AUTH_PASSWORD="admin12345"
